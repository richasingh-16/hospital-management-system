generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id    String @id @default(uuid())
  name  String
  age   Int
  gender String
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
}

model User {
  id         String   @id @default(uuid())
  employeeId String   @unique
  name       String
  password   String
  role       Role
  createdAt  DateTime @default(now())

  doctor Doctor?
}

model Doctor {
  id             String  @id @default(uuid())
  userId         String  @unique
  departmentId   String
  specialization String
  experience     Int

  user       User       @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId], references: [id])
}

model Department {
  id   String @id @default(uuid())
  name String @unique

  doctors Doctor[]
}