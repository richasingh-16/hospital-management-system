generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  employeeId String   @unique
  name       String
  password   String
  role       Role
  createdAt  DateTime @default(now())
  doctor     Doctor?
}

model Patient {
  id            String        @id @default(uuid())
  name          String
  age           Int
  gender        String
  createdAt     DateTime      @default(now())
  condition     String?
  contact       String?
  doctor        String?
  status        String?       @default("OPD")
  ward          String?       @default("General")
  patientNumber Int           @default(autoincrement())
  admissions    Admission[]
  appointments  Appointment[]
  invoices      Invoice[]
  labReports    LabReport[]
}

model Department {
  id      String   @id @default(uuid())
  name    String   @unique
  doctors Doctor[]
}

model Ward {
  id        String   @id @default(uuid())
  name      String   @unique
  floor     Int
  capacity  Int
  createdAt DateTime @default(now())
  beds      Bed[]
}

model Bed {
  id         String      @id @default(uuid())
  wardId     String
  number     Int
  status     BedStatus   @default(AVAILABLE)
  createdAt  DateTime    @default(now())
  admissions Admission[]
  ward       Ward        @relation(fields: [wardId], references: [id])
}

model Doctor {
  id             String        @id @default(uuid())
  userId         String        @unique
  departmentId   String
  specialization String
  experience     Int
  createdAt      DateTime      @default(now())
  patientsToday  Int           @default(0)
  phone          String
  status         DoctorStatus  @default(AVAILABLE)
  admissions     Admission[]
  appointments   Appointment[]
  department     Department    @relation(fields: [departmentId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Appointment {
  id                String            @id @default(uuid())
  doctorId          String
  patientId         String
  createdAt         DateTime          @default(now())
  dateTime          DateTime
  notes             String?
  status            AppointmentStatus @default(SCHEDULED)
  appointmentNumber Int               @default(autoincrement())
  doctor            Doctor            @relation(fields: [doctorId], references: [id])
  patient           Patient           @relation(fields: [patientId], references: [id])
}

model Admission {
  id              String   @id @default(uuid())
  patientId       String
  doctorId        String
  bedId           String
  reason          String
  createdAt       DateTime @default(now())
  admissionNumber Int      @default(autoincrement())
  bed             Bed      @relation(fields: [bedId], references: [id])
  doctor          Doctor   @relation(fields: [doctorId], references: [id])
  patient         Patient  @relation(fields: [patientId], references: [id])
}

model Invoice {
  id            String        @id @default(uuid())
  patientId     String
  doctorName    String
  doctorFee     Float         @default(0)
  labTests      Float         @default(0)
  medication    Float         @default(0)
  roomCharges   Float         @default(0)
  status        InvoiceStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  invoiceNumber Int           @default(autoincrement())
  patient       Patient       @relation(fields: [patientId], references: [id])
}

model LabReport {
  id             String    @id @default(uuid())
  patientId      String?
  patientName    String
  testType       String
  orderedBy      String
  status         LabStatus @default(PENDING)
  resultFilePath String?
  resultFileName String?
  createdAt      DateTime  @default(now())
  reportNumber   Int       @default(autoincrement())
  patient        Patient?  @relation(fields: [patientId], references: [id])
}

model ActivityLog {
  id         String   @id @default(uuid())
  actionType String
  message    String
  actor      String
  createdAt  DateTime @default(now())
}

model HospitalSetting {
  key   String @id
  value String
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  LAB_TECHNICIAN
}

enum DoctorStatus {
  AVAILABLE
  BUSY
  IN_SURGERY
  ON_LEAVE
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum InvoiceStatus {
  PAID
  PENDING
  OVERDUE
}

enum LabStatus {
  PENDING
  PROCESSING
  READY
}
